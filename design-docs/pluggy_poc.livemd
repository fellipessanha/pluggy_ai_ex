```elixir
pluggy_url = "https://api.pluggy.ai"
baseline_headers = [accept: "application/json", "content-type": "application/json"]
client_auth = %{
  clientId: "8911d073-91d1-4cf7-bb57-726f46897b68",
  clientSecret: "4ad9d3ce-c434-444c-8c22-debd5963dfbd",
}

base_req = Req.new(base_url: pluggy_url, headers: baseline_headers)
```

```elixir
%Req.Response{
  status: 200, headers: auth_headers, body: auth_response_body
} =  Req.post!(base_req, url: "/auth", json: client_auth)
```

```elixir
%{"apiKey" => auth_api_key} = auth_response_body
authorized_headers = Keyword.put(baseline_headers,  String.to_atom("X-API-KEY"), auth_api_key)
auth_req = Req.new(base_url: pluggy_url, headers: authorized_headers)
```

```elixir
connectors_list = Req.get!(auth_req, url: "/connectors")
```

```elixir
connectors_simplified = for %{
  "name" => con_name, "id" => con_id, "products" => con_prods
} <- connectors_list.body["results"],
  do: %{name: con_name, id: con_id, products: con_prods}

connectors_simplified |> Enum.sort(&(&1.name <= &2.name))
```

